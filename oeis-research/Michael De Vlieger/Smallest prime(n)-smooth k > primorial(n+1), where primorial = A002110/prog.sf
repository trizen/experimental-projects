#!/usr/bin/ruby

# Smallest prime(n)-smooth k > primorial(n+1), where primorial = A002110.
# https://oeis.org/A394581

# New terms:
#   a(16) = 1922760351270804488400      (found in 1 min, 38 sec)
#   a(17) = 117288381369590011752500
#   a(18) = 7858321551352441818943371   (found in ~40 minutes)

for n in (1..20) {
    say ("a(#{n}) = ", nth_smooth(n.prime.smooth_count(pn_primorial(n+1))+1, n.prime))
}

__END__
