#!/usr/bin/ruby

# Largest prime(n)-smooth k < primorial(n+1), where primorial = A002110.
# https://oeis.org/A394580

# New terms:
#   a(17) = 117288381279853990384794
#   a(18) = 7858321550788671875000000 (found in ~40 minutes)

 for n in (1..20) {
    say ("a(#{n}) = ", nth_smooth(n.prime.smooth_count(pn_primorial(n+1)), n.prime))
}

__END__
