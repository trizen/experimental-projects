#!/usr/bin/ruby

# a(n) is the largest integer k < 2^(n-1) for which the number of divisors is equal to n, or 0 if no such k exists.
# https://oeis.org/A395952

for n in (1..100) {
    say (n, " ", (prev_tau_inverse(2**(n-1), n) || 0))
}

